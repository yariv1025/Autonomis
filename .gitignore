# Runtime state (plugin creates these; keep README and config.example)
.autonomis/state/
.autonomis/runs/
.autonomis/memory/
.autonomis/research/
.autonomis/config

# Eval workspaces (recreate when running evals; do not ship)
plugins/autonomis/skills/*-workspace/
# Local skill/plugin tooling (do not ship)
plugins/autonomis/skills/.agents/
plugins/autonomis/skills/.cursor/

# Planning / process docs (keep locally; not part of published plugin)
docs/evals-pipeline.md
docs/design-review-rubric.md
docs/eval-comparison-feedback.md

# Dev tooling: .agents/ is INCLUDED so contributors can run evals (see README).
# Do not add .agents/ here.

# OS and editors
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Node (if we add tooling later)
node_modules/
npm-debug.log*
yarn-error.log*

# Python (if we add tooling later)
__pycache__/
*.py[cod]
.venv/
venv/
.env
.env.local

# IDE
.idea/
.vscode/
*.code-workspace
